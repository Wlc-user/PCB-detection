<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- 服务器配置 -->
    <add key="GrpcServer" value="localhost:50051" />
    <add key="WsServer" value="ws://localhost:8765" />
    
    <!-- 协议选择: grpc / websocket -->
    <add key="Protocol" value="grpc" />
    
    <!-- 检测配置 -->
    <add key="ConfidenceThreshold" value="0.25" />
    <add key="IoUThreshold" value="0.45" />
    
    <!-- 显示配置 -->
    <add key="MaxFps" value="30" />
    <add key="ShowLabels" value="true" />
    <add key="ShowConfidence" value="true" />
    <add key="DrawBoxes" value="true" />
    
    <!-- 日志配置 -->
    <add key="LogLevel" value="Info" />
    <add key="LogToFile" value="true" />
  </appSettings>
</configuration>
