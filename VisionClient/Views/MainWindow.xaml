<Window x:Class="VisionClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Vision Client - PCB缺陷检测" 
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource DarkBgBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenImageCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding OpenVideoCommand}"/>
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding ConnectCommand}"/>
        <KeyBinding Key="Space" Command="{Binding SnapshotCommand}"/>
    </Window.InputBindings>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{StaticResource LightBgBrush}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo + 标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="👁" FontSize="24" Foreground="{StaticResource PrimaryBrush}" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Vision Client" FontSize="18" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 连接状态 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 连接状态指示 -->
                    <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource WarningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="White" 
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    
                    <!-- 连接按钮 -->
                    <Button Content="{Binding ConnectButtonText}" 
                            Style="{StaticResource ButtonStyle}"
                            Command="{Binding ConnectCommand}"
                            Margin="0,0,8,0"/>
                    
                    <!-- 协议选择 -->
                    <ComboBox x:Name="ProtocolCombo" Width="100" SelectedIndex="0" 
                              VerticalAlignment="Center" Margin="0,0,8,0">
                        <ComboBoxItem Content="gRPC" Tag="grpc"/>
                        <ComboBoxItem Content="WebSocket" Tag="websocket"/>
                    </ComboBox>
                    
                    <!-- 设置按钮 -->
                    <Button Content="⚙" FontSize="16" Width="40" Height="36"
                            Style="{StaticResource ButtonStyle}"
                            Click="Settings_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：图像显示区 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 标题栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="实时图像" Style="{StaticResource HeaderStyle}"/>
                        <TextBlock x:Name="ImageInfoText" Foreground="#888888" 
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                    
                    <!-- 图像显示 -->
                    <Border Grid.Row="1" Background="#151515" CornerRadius="4">
                        <Grid>
                            <!-- 原始图像 -->
                            <Image x:Name="ImageDisplay" Stretch="Uniform" 
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            
                            <!-- 加载动画 -->
                            <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                                <TextBlock Text="处理中..." Foreground="White" 
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                            
                            <!-- 拖放提示 -->
                            <Border x:Name="DropHintPanel" Background="#30000000" 
                                    Visibility="Visible">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📁" FontSize="48" HorizontalAlignment="Center"/>
                                    <TextBlock Text="拖放图像或视频到这里" Foreground="White" 
                                               FontSize="16" Margin="0,8,0,0"/>
                                    <TextBlock Text="Ctrl+O 打开图像 | Ctrl+S 打开视频" 
                                               Foreground="#888888" FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- 底部控制栏 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" 
                                VerticalAlignment="Bottom" Margin="0,12,0,0">
                        <Button Content="📂 打开图像" Style="{StaticResource ButtonStyle}"
                                Command="{Binding OpenImageCommand}" Margin="0,0,8,0"/>
                        <Button Content="🎬 打开视频" Style="{StaticResource ButtonStyle}"
                                Command="{Binding OpenVideoCommand}" Margin="0,0,8,0"/>
                        <Button Content="📷 摄像头" Style="{StaticResource ButtonStyle}"
                                Command="{Binding StartCameraCommand}" Margin="0,0,8,0"/>
                        <Button Content="📸 截图" Style="{StaticResource ButtonStyle}"
                                Command="{Binding SnapshotCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 右侧面板 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 性能统计 -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="性能统计" Style="{StaticResource HeaderStyle}"/>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- FPS -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Fps}" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Text="FPS" Style="{StaticResource LabelStyle}"/>
                            </StackPanel>
                            
                            <!-- 延迟 -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Latency}" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Text="延迟(ms)" Style="{StaticResource LabelStyle}"/>
                            </StackPanel>
                            
                            <!-- 检测数 -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding DetectionCount}" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Text="检测数" Style="{StaticResource LabelStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- 检测结果列表 -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="检测结果" Style="{StaticResource HeaderStyle}"/>
                        
                        <ListBox x:Name="DetectionListBox" Grid.Row="1" 
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                    <Setter Property="Background" Value="#3F3F46"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" 
                                                   Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Confidence}" 
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <!-- 空状态 -->
                        <TextBlock x:Name="EmptyResultText" Grid.Row="1"
                                   Text="暂无检测结果" Foreground="#555555" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Visible"/>
                    </Grid>
                </Border>
                
                <!-- 快捷配置 -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="检测配置" Style="{StaticResource HeaderStyle}"/>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 置信度 -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="置信度" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                <Slider x:Name="ConfidenceSlider" Minimum="0.1" Maximum="0.9" 
                                        Value="0.25" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        ValueChanged="Confidence_Changed"/>
                                <TextBlock x:Name="ConfidenceValue" Text="0.25" 
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- IoU -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="IoU阈值" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                <Slider x:Name="IoUSlider" Minimum="0.3" Maximum="0.7" 
                                        Value="0.45" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        ValueChanged="IoU_Changed"/>
                                <TextBlock x:Name="IoUValue" Text="0.45" 
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="{StaticResource LightBgBrush}" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 日志 -->
                <TextBlock x:Name="StatusText" Grid.Column="0" 
                           Text="就绪" Foreground="#888888" VerticalAlignment="Center"/>
                
                <!-- 版本 -->
                <TextBlock Grid.Column="1" Text="v1.0.0 | gRPC + WebSocket" 
                           Foreground="#555555" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
